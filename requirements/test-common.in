pytest_codspeed; sys_platform != 'android' and sys_platform != 'ios'
python-on-whales; sys_platform != 'android' and sys_platform != 'ios'
setuptools-git
trustme; platform_machine != "i686" and sys_platform != 'android' and sys_platform != 'ios' # no 32-bit and android and ios wheels
wait-for-it
