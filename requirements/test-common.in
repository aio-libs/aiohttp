mypy; implementation_name == "cpython" and sys_platform != 'android' and sys_platform != 'ios'
mypy-extensions; sys_platform != 'android' and sys_platform != 'ios'  # used by mypy
pkgconfig
proxy.py >= 2.4.4rc5
